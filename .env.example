# Copy to .env (gitignored) and fill in real values before `docker compose up`.
# Requires AfyaSignal checked out as a sibling directory — see docker-compose.yml.

# Shared Postgres instance (two logical databases: afyasignal, afyasignal_autopilot)
POSTGRES_DB=afyasignal
POSTGRES_USER=afyasignal
POSTGRES_PASSWORD=change-me

# AfyaSignal backend
JWT_SECRET=change-me
GEMINI_API_KEY=unused-dummy-key
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Shared AUTOPILOT service-account password (must match AfyaSignal's ServiceAccountSeeder)
AUTOPILOT_SERVICE_PASSWORD=change-me

# afyasignal-autopilot
DASHSCOPE_API_KEY=sk-ws-change-me
